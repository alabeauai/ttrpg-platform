# ── Google OAuth ─────────────────────────────────────────────────────────────
# Setup: https://console.cloud.google.com → New Project → APIs & Services → Credentials
# Create OAuth 2.0 Client ID → Web Application
# Add redirect URI: http://localhost:3001/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── GitHub OAuth ─────────────────────────────────────────────────────────────
# Setup: GitHub → Settings → Developer Settings → OAuth Apps → New OAuth App
# Homepage URL: http://localhost:3001
# Callback URL: http://localhost:3001/auth/github/callback
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# ── Apple OAuth ───────────────────────────────────────────────────────────────
# Requires Apple Developer account ($99/year)
# Setup: developer.apple.com → Certificates → Services ID → Sign In with Apple
# Also create a Key with "Sign in with Apple" enabled → download .p8 file
# NOTE: Apple requires HTTPS in production. Localhost works for dev only with some configs.
APPLE_CLIENT_ID=com.yourapp.signin
APPLE_TEAM_ID=YOUR10CHAR
APPLE_KEY_ID=KEY10CHARID
APPLE_PRIVATE_KEY_PATH=./AuthKey_XXXXXX.p8

# ── Session ───────────────────────────────────────────────────────────────────
# Generate a random secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change_this_to_a_long_random_string

# ── App ───────────────────────────────────────────────────────────────────────
PORT=3001
BASE_URL=http://localhost:3001
